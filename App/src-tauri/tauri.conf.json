{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Universe AI",
  "version": "0.1.0",
  "identifier": "ai.universe.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Universe AI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4RkYwNjVCMUM2QUFDRjEKUldUeHJHb2NXd2IvU04xZVI4am9HT2FxU0xnTlk1N3ZmUDF2aDBLNXVFUFVwN2JXUFJjaktxTWcK",
      "endpoints": [
        "https://github.com/InTheNightRaider/ComputerAgent2/releases/latest/download/latest.json"
      ]
    }
  }
}
